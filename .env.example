# ──────────────────────────────────────────────────────────────
#  Pi Guardian — environment configuration
#  Copy to `.env` and fill in your own values:  cp .env.example .env
#  NEVER commit your real .env file.
# ──────────────────────────────────────────────────────────────

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=8080
REFRESH_INTERVAL=5          # live-stats push interval (seconds)
DEVICE_NAME=Pi Guardian
WEATHER_CITY=London

# ── Demo mode ─────────────────────────────────────────────────
# Set to 1 to run with realistic synthetic data — no Raspberry Pi,
# no AdGuard/Pi-hole/Healthchecks required. Great for trying it out.
DEMO_MODE=0

# ── Dashboard authentication (built-in admin account) ─────────
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-please
# Random secret for signing sessions. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-a-long-random-string

# ── AdGuard Home ──────────────────────────────────────────────
AGH_HOST=http://192.168.1.50
AGH_USER=adguard
AGH_PASS=

# ── Alert thresholds ──────────────────────────────────────────
ALERT_CPU_TEMP=75           # °C
ALERT_CPU_USAGE=90          # %
ALERT_RAM_USAGE=90          # %
ALERT_DISK_USAGE=85         # %
REPORT_HOURS=12             # hours of history included in reports

# ── Tailscale (optional, for remote links in e-mails) ─────────
TAILSCALE_IP=

# ── Gmail (optional, for registration approval e-mails) ───────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASS=             # Google App Password (not your login password)
EMAIL_TO=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Telegram (optional, for push alerts) ──────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── Healthchecks.io (optional, dead-man's-switch monitoring) ──
HC_API_KEY=
HC_UUID=
HC_PING_URL=

# ── Uptime Kuma (optional) ────────────────────────────────────
UPTIME_KUMA_URL=http://localhost:3001
UPTIME_KUMA_API_KEY=
UPTIME_KUMA_PUSH_URL=
